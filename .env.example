# Strobes Shell Bridge Agent Configuration
# Copy to .env and fill in your values

# Required
STROBES_URL=https://app.strobes.co
STROBES_API_KEY=your-api-key-here
STROBES_ORG_ID=your-org-uuid-here

# Optional
# STROBES_BRIDGE_ID=auto-generated-if-not-set
# STROBES_SHELL_NAME=my-server
# STROBES_CWD=/home/user
# STROBES_VERBOSE=true
